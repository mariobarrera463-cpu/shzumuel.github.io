{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and game progress",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "lastPlayed": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "favorites"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    }
  }
}
