rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100
          && data.favorites is list
          && data.favorites.size() <= 500
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
                    && isValidUser(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'lastPlayed', 'updatedAt', 'displayName', 'photoURL']);
    }
  }
}
